\subsubsection{Структурное описание}

\begin{lstlisting}[language=Verilog]
module rsff (q,clock,r,s);

input clock, r, s;
output reg q = 0;

always @(posedge clock)
if (r && s) q <= 1'bx;
else if (s) q <= 1'b1;
else if (r) q <= 1'b0;
endmodule

module lab521 #(parameter mode="sub")
(output [4:0] b, input clock);

wire [4:0] r, s, q;
genvar i;

generate
if (mode=="add") begin // Johnson
for (i = 0; i < 4; i = i + 1) rsff rsffi (q[i],clock,r[i],s[i]);
assign r[3] = ~q[2],
       s[3] = q[2],
       r[2] = ~q[1],
       s[2] = q[1],
       r[1] = ~q[0],
       s[1] = q[0],
       r[0] = q[3],
       s[0] = ~q[3];
end

else if (mode=="sub") begin // binary-arithmetic
for (i = 0; i < 4; i = i + 1) rsff rsffi (q[i],clock,r[i],s[i]);
assign r[3] = q[3] & ~q[2] & ~q[1] & ~q[0],
       s[3] = ~q[3] & ~q[2] & ~q[1] & ~q[0],
       r[2] = q[2] & ~q[1] & ~q[0],
       s[2] = ~q[2] & ~q[1] & ~q[0],
       r[1] = q[1] & ~q[0],
       s[1] = ~q[1] & ~q[0],
       r[0] = q[0],
       s[0] = ~q[0];
end

else if (mode=="reverse") begin // reverse
for (i = 0; i < 5; i = i + 1) rsff rsffi (q[i],clock,r[i],s[i]);
// q[4] == dir
assign r[4] = ~q[3] & ~q[2] & ~q[1] & ~q[0],
       s[4] = q[3] & ~q[2],
       r[3] = q[4] & ~q[2] & ~q[1] & ~q[0],
       s[3] = ~q[4] & q[2],
       r[2] = q[2] & ~q[1] & ~q[0],
       s[2] = (~q[4] & q[1]) | (q[3] & ~q[2] & ~q[1] & ~q[0]),
       r[1] = q[1] & ~q[0],
       s[1] = (~q[4] & q[0]) | (q[4] & q[2] & ~q[1] & ~q[0]) |
              (q[3] & ~q[2] & ~q[1] & ~q[0]),
       r[0] = (q[4] & q[0]) | (q[3] & q[0]),
       s[0] = (~q[4] & ~q[2]) | (q[4] & q[2] & ~q[0]) |
              (q[4] & ~q[3] & ~q[2] & q[1] & ~q[0]) |
              (q[4] & q[3] & ~q[0] & ~q[2]);
end
endgenerate

assign b = q;

endmodule
\end{lstlisting}

